# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (e.g. the frontend dev server)
CORS_ORIGIN=http://localhost:3000

# Postgres connection string (e.g. Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign JWTs (use a long random string in production)
JWT_SECRET=change-me

# Optional: when both are set, `npm run db:seed` creates (or promotes) this
# user as an admin so the admin-only endpoints are usable.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=use-a-strong-password

